extends ../../layout/default.pug
include ../../mixins/alert.pug

block main
    +alert(messages)

    .container-fluid
        .row.mb-4
            .col-12
                h1.mb-3 Account Details

        .row
            .col-lg-8
                .card
                    .card-body
                        .row.mb-4
                            .col-md-4.text-center
                                if account.avatar
                                    img(src=account.avatar alt=account.fullName style="width: 200px; height: 200px; border-radius: 50%; object-fit: cover;")
                                else
                                    i.fas.fa-user-circle(style="font-size: 200px; color: #ccc;")

                            .col-md-8
                                .row.mb-3
                                    .col-12
                                        h4= account.fullName || 'N/A'
                                        small.text-muted Account ID: #{account._id}

                                .row.mb-3
                                    .col-12
                                        label.fw-bold Email:
                                        p.mb-0= account.email

                                .row.mb-3
                                    .col-md-6
                                        label.fw-bold Telephone:
                                        p.mb-0= account.phone || 'N/A'

                                    .col-md-6
                                        label.fw-bold Status:
                                        p.mb-0
                                            if account.status === 'active'
                                                span.badge.bg-success Active
                                            else
                                                span.badge.bg-danger Inactive

                        hr

                        .row.mb-3
                            .col-md-6
                                label.fw-bold Role:
                                p.mb-0
                                    span.badge.bg-primary= account.role_id.title || 'N/A'

                            .col-md-6
                                label.fw-bold Role Description:
                                p.mb-0
                                    small= account.role_id.description ? account.role_id.description.replace(/<[^>]*>/g, '') : 'No description' 

                        if account.role_id.permissions && account.role_id.permissions.length > 0
                            .row.mb-3
                                .col-12
                                    label.fw-bold Permissions:
                                    p.mb-0
                                        each permission in account.role_id.permissions
                                            span.badge.bg-info.me-2= permission

                        hr

                        .row.mb-3
                            .col-md-6
                                label.fw-bold Created At:
                                p.mb-0= new Date(account.createdAt).toLocaleDateString('vi-VN')

                            .col-md-6
                                label.fw-bold Last Updated:
                                p.mb-0= new Date(account.updatedAt).toLocaleDateString('vi-VN')

                        hr

                        .d-flex.gap-2
                            a.btn.btn-warning(href=`${prefixAdmin}/accounts/edit/${account._id}`)
                                i.fas.fa-edit
                                |  Edit
                            a.btn.btn-secondary(href=`${prefixAdmin}/accounts`)
                                i.fas.fa-arrow-left
                                |  Back

