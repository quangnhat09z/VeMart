extends ../../layout/default.pug
include ../../mixins/alert.pug

block main 
    //Chat page styles
    link(rel="stylesheet" href="/client/styles/css/chat.css")
    +alert(messages)
    .container
        div(class="custom-file-container" data-upload-id="upload-images" style="display: none;")

        #chat-window.chat__window
            .chat__header
                span.chat__title
                    i.fas.fa-user-tie
                    |  Admin
                button#chat-close.chat__close(aria-label="Đóng")
                    i.fas.fa-times
            .chat__body
                #chat-messages.chat__messages(myid=user.id)
                    for chat in chats
                        if chat.user_id === user._id.toString()                          
                            .chat__message.chat__message--user
                                if (chat.content)
                                    .chat__message-content
                                        | #{chat.content}  
                                .chat__message-image.chat__message-image--user        
                                    each image in chat.images
                                        img(src=image, alt="User Image")
                        else 
                            .chat__message.chat__message--bot
                                if (chat.content)
                                    .chat__message-name #{chat.infoUser}
                                    .chat__message-content
                                        | #{chat.content}               
                                .chat__message-image.chat__message-image--bot        
                                    each image in chat.images
                                        img(src=image, alt="User Image")


            .chat__footer
                .image-preview-box
                form#chat-form.chat__form
                    button.chat-attach-image(type="button" aria-label="Đính kèm")
                        i.fa-regular.fa-image
                    textarea(id="chat-input" class="chat__input" rows="1" placeholder="Type a message...")
                    .chat-emoji
                        i.fas.fa-smile
                    emoji-picker(id="emoji-picker" class="emoji-picker")
                    button.chat__send(type="submit" aria-label="Gửi")
                        i.fas.fa-paper-plane


